{
    "version": 2,
    "builds": [
        {
            "src": "app.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.js"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/send-reminders",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/api/cron/cleanup",
            "schedule": "0 3 * * 1"
        }
    ]
}